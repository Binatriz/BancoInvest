@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Banco Invest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
            body {
                background: radial-gradient(circle at top, #0f0f0f, #000);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-family: 'Segoe UI', sans-serif;
            }

            .login-box {
                background: rgba(20, 20, 20, 0.9);
                backdrop-filter: blur(10px);
                border-radius: 20px;
                padding: 40px 30px;
                width: 320px;
                text-align: center;
                box-shadow: 0 0 25px rgba(0, 255, 150, 0.2);
            }

            .avatar {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                margin-bottom: 20px;
                border: 2px solid #00ff9c;
                box-shadow: 0 0 10px #00ff9c;
            }

            .input-group {
                margin-bottom: 15px;
            }

            .input-group-text {
                background: transparent;
                border: 1px solid #00ff9c;
                color: #00ff9c;
            }

            .form-control {
                background: transparent;
                border: 1px solid #00ff9c;
                color: white;
            }

                .form-control:focus {
                    background: transparent;
                    border-color: #00ff9c;
                    box-shadow: 0 0 10px #00ff9c;
                    color: white;
                }

            .btn-bank {
                background: linear-gradient(90deg, #00ff9c, #00c97a);
                border: none;
                color: black;
                font-weight: bold;
                margin-top: 10px;
            }

                .btn-bank:hover {
                    box-shadow: 0 0 15px #00ff9c;
                    transform: scale(1.05);
                }

            .erro {
                color: #ff4d4d;
                margin-bottom: 10px;
            }
    </style>
</head>
<body>

    <div class="login-box">

        <!-- 👤 Avatar -->
        <img src="https://cdn-icons-png.flaticon.com/512/847/847969.png" class="avatar" />

        @if (TempData["Erro"] != null)
        {
            <div class="erro">@TempData["Erro"]</div>
        }

        <form method="post" action="/Auth/Login">

            <!-- EMAIL -->
            <div class="input-group">
                <span class="input-group-text">
                    <i class="fa fa-user"></i>
                </span>
                <input name="email" class="form-control" placeholder="Email" />
            </div>

            <!-- SENHA -->
            <div class="input-group">
                <span class="input-group-text">
                    <i class="fa fa-lock"></i>
                </span>
                <input type="password" name="senha" class="form-control" placeholder="Senha" />
            </div>

            <button class="btn btn-bank w-100">Entrar</button>

        </form>
    </div>

</body>
</html>