@using BancoInvest.Models
@model BancoInvest.Models.Conta

@{
    ViewData["Title"] = "Câmbio";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: radial-gradient(circle at top, #002d25, #000);
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .app-container {
        max-width: 90%;
        margin: 30px auto;
        background: #0f0f0f;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 0 40px rgba(0,255,156,0.15);
    }

    .content {
        padding: 20px;
    }

    .topo {
        background: linear-gradient(180deg, #00ff9c, #007a5a);
        padding: 20px;
        border-radius: 0 0 25px 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .titulo {
        font-size: 20px;
        font-weight: bold;
    }

    .btn-voltar {
        border: 1px solid #00ff9c;
        color: #00ff9c;
        padding: 6px 12px;
        border-radius: 10px;
        text-decoration: none;
    }

        .btn-voltar:hover {
            background: #00ff9c;
            color: black;
        }

    .card-box {
        background: #121212;
        border-radius: 15px;
        padding: 20px;
        margin-top: 20px;
        box-shadow: 0 0 10px rgba(0,255,156,0.08);
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }

    .input {
        background: #1a1a1a;
        border: 1px solid #00ff9c;
        border-radius: 10px;
        padding: 10px;
        color: white;
        width: 100%;
        margin-top: 10px;
    }

    .btn-acao {
        background: linear-gradient(90deg, #00ff9c, #00c97a);
        border: none;
        color: black;
        padding: 12px;
        width: 100%;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 15px;
        transition: 0.2s;
    }

        .btn-acao:hover {
            transform: scale(1.02);
        }

    .destaque {
        color: #00ff9c;
        font-weight: bold;
    }

    .resumo {
        margin-top: 10px;
        font-size: 14px;
    }
</style>

<div class="app-container">

    <!-- TOPO -->
    <div class="topo">
        <div class="titulo">💱 Câmbio (BRL → Moeda)</div>
        <a href="/Conta/Index" class="btn-voltar">Voltar</a>
    </div>

    <div class="content">

        <!-- SALDO -->
        <div class="card-box text-center">
            Saldo disponível:
            <div class="destaque" style="font-size:20px;">
                R$ @Model.SaldoBRL.ToString("N2")
            </div>
        </div>

        <!-- FORM SIMULAÇÃO -->
        <form method="post" action="/Conta/SimularCambio">

            <div class="card-box">

                <label>Valor em BRL</label>
                <input type="number" step="0.01" name="valor" class="input" required />

                <label class="mt-3">Converter para</label>
                <select name="moeda" class="input">
                    <option value="USD">USD (Dólar)</option>
                    <option value="EUR">EUR (Euro)</option>
                    <option value="GBP">GBP (Libra)</option>
                    <option value="JPY">JPY (Iene)</option>
                </select>

                <button class="btn-acao">
                    Simular Conversão
                </button>

            </div>

        </form>

        <!-- RESULTADO -->
        @if (ViewBag.Simulacao != null)
        {
            var s = ViewBag.Simulacao;

            <div class="card-box">

                <div class="titulo">📊 Resultado</div>

                <div class="resumo">
                    De: <span class="destaque">R$ @s.Valor.ToString("N2")</span>
                </div>

                <div class="resumo">
                    Para: <span class="destaque">@s.Moeda</span>
                </div>

                <div class="resumo">
                    Taxa: <span class="destaque">@s.Taxa</span>
                </div>

                <div class="resumo">
                    Você receberá:
                    <span class="destaque">
                        @s.Convertido.ToString("N2") @s.Moeda
                    </span>
                </div>

                <!-- CONFIRMAR -->
                <form method="post" action="/Conta/ConfirmarCambio">
                    <input type="hidden" name="valor" value="@s.Valor" />
                    <input type="hidden" name="moeda" value="@s.Moeda" />

                    <button class="btn-acao">
                        Confirmar Câmbio
                    </button>
                </form>

            </div>
        }

        <!-- HISTÓRICO -->
        @if (Model.Cambios != null && Model.Cambios.Any())
        {
            <div class="card-box">

                <div class="titulo">📄 Histórico</div>

                @foreach (var c in Model.Cambios.OrderByDescending(x => x.DataHora))
                {
                    <div class="card-box" style="background:#1a1a1a; margin-top:10px;">

                        <div class="resumo">
                            💱 BRL → @c.MoedaDestino
                        </div>

                        <div class="resumo">
                            R$ @c.ValorOrigem.ToString("N2")
                            →
                            <span class="destaque">
                                @c.ValorConvertido.ToString("N2") @c.MoedaDestino
                            </span>
                        </div>

                        <div class="resumo">
                            📅 @c.DataHora.ToString("dd/MM/yyyy HH:mm")
                        </div>

                    </div>
                }

            </div>
        }

    </div>
</div>