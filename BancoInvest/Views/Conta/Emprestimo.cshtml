@using BancoInvest.Models
@model BancoInvest.Models.Conta

@{
    ViewData["Title"] = "Empréstimo";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: radial-gradient(circle at top, #002d25, #000);
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .app-container {
        max-width: 90%;
        margin: 30px auto;
        background: #0f0f0f;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 0 40px rgba(0,255,156,0.15);
    }

    .content {
        padding: 20px;
    }

    .topo {
        background: linear-gradient(180deg, #00ff9c, #007a5a);
        padding: 20px;
        border-radius: 0 0 25px 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .titulo {
        font-size: 20px;
        font-weight: bold;
    }

    .btn-voltar {
        background: transparent;
        border: 1px solid #00ff9c;
        color: #00ff9c;
        padding: 6px 12px;
        border-radius: 10px;
        text-decoration: none;
    }

    .card-box {
        background: #121212;
        border-radius: 15px;
        padding: 20px;
        margin-top: 20px;
        box-shadow: 0 0 10px rgba(0,255,156,0.08);
    }

    .input {
        background: #1a1a1a;
        border: none;
        border-radius: 10px;
        padding: 10px;
        color: white;
        width: 100%;
        margin-top: 10px;
    }

    .btn-acao {
        background: #00ff9c;
        border: none;
        color: black;
        padding: 12px;
        width: 100%;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 15px;
        transition: 0.2s;
    }

        .btn-acao:hover {
            background: #00c77a;
        }

    .resumo {
        margin-top: 15px;
        font-size: 14px;
        opacity: 0.9;
    }

    .destaque {
        color: #00ff9c;
        font-weight: bold;
    }
</style>

<div class="app-container">

    <!-- TOPO -->
    <div class="topo">
        <div class="titulo">💳 Empréstimo</div>
        <a href="/Conta/Index" class="btn-voltar">Voltar</a>
    </div>

    <div class="content">

        @{
            var totalDivida = Model.Emprestimos?
                .Where(e => e.Status == StatusEmprestimo.Aprovado)
                .Sum(e => e.ValorAprovado + (e.ValorAprovado * e.TaxaJuros / 100 * e.NumeroParcelas)) ?? 0;
        }

        <!-- 💸 TOTAL DA DÍVIDA -->
        <div class="card-box">
            <div class="titulo">💸 Total da Dívida</div>

            <div class="resumo">
                <span class="destaque" style="font-size:18px;">
                    R$ @totalDivida.ToString("N2")
                </span>
            </div>
        </div>

        <!-- 📋 LISTA DE EMPRÉSTIMOS -->
        @if (Model.Emprestimos != null && Model.Emprestimos.Any())
        {
            <div class="card-box">

                <div class="titulo">📋 Meus Empréstimos</div>

                @foreach (var emp in Model.Emprestimos
                                    .OrderByDescending(e => e.DataSolicitacao))
                {
                    <div class="card-box" style="background:#1a1a1a; margin-top:15px;">

                        <div class="resumo">
                            💰 Valor:
                            <span class="destaque">
                                R$ @emp.ValorAprovado.ToString("N2")
                            </span>
                        </div>

                        <div class="resumo">
                            📆 Parcelas:
                            <span class="destaque">@emp.NumeroParcelas x</span>
                        </div>

                        <div class="resumo">
                            📊 Status:
                            <span class="destaque">@emp.Status</span>
                        </div>

                        <div class="resumo">
                            🗓 Data:
                            @emp.DataSolicitacao.ToString("dd/MM/yyyy")
                        </div>

                    </div>
                }

            </div>
        }

        <!-- FORM -->
        <form method="post" action="/Conta/Emprestimo">

            <div class="alert alert-info text-dark">
                💳 Limite disponível:
                <strong>
                    R$ @Model.LimiteEmprestimo.ToString("N2")
                </strong>
            </div>

            <div class="card-box">
                <label>Valor desejado (R$)</label>
                <input type="number" step="0.01" name="valor" class="input" required />

                <label class="mt-3">Parcelas</label>
                <select name="parcelas" class="form-control mb-2">
                    @for (int i = 1; i <= 24; i++)
                    {
                        <option value="@i">@i x</option>
                    }
                </select>

                <button type="submit" class="btn-acao">
                    Simular / Contratar
                </button>
            </div>

        </form>

        <!-- SIMULAÇÃO -->
        @if (ViewBag.Simulacao != null)
        {
            var s = ViewBag.Simulacao;

            <div class="card-box">

                <div class="titulo">📊 Resumo do Empréstimo</div>

                <div class="resumo">
                    Valor solicitado:
                    <span class="destaque">R$ @s.Valor.ToString("N2")</span>
                </div>

                <div class="resumo">
                    Parcelas:
                    <span class="destaque">@s.Parcelas x</span>
                </div>

                <div class="resumo">
                    Juros:
                    <span class="destaque">@s.Juros % ao mês</span>
                </div>

                <div class="resumo">
                    Valor da parcela:
                    <span class="destaque">R$ @s.Parcela.ToString("N2")</span>
                </div>

                <div class="resumo">
                    Total a pagar:
                    <span class="destaque">R$ @s.Total.ToString("N2")</span>
                </div>

                <form method="post" action="/Conta/ConfirmarEmprestimo">
                    <input type="hidden" name="valor" value="@s.Valor" />
                    <input type="hidden" name="parcelas" value="@s.Parcelas" />

                    <button class="btn-acao">
                        Confirmar Empréstimo
                    </button>
                </form>

            </div>
        }

    </div>
</div>