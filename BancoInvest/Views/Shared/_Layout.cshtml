<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background: #0a0a0a;
                color: #eaeaea;
                font-family: 'Segoe UI', sans-serif;
            }

            /* NAVBAR */
            .navbar {
                background: #000;
                border-bottom: 1px solid #00ff88;
                box-shadow: 0 0 10px #00ff88;
            }

            /* CARDS */
            .card-banco {
                background: #121212;
                border-radius: 15px;
                padding: 20px;
                box-shadow: 0 0 10px rgba(0,255,136,0.2);
                transition: 0.3s;
            }

                .card-banco:hover {
                    box-shadow: 0 0 20px rgba(0,255,136,0.6);
                    transform: scale(1.02);
                }

            /* BOTÕES */
            .btn-neon {
                background: transparent;
                border: 1px solid #00ff88;
                color: #00ff88;
                font-weight: bold;
                transition: 0.3s;
            }

                .btn-neon:hover {
                    background: #00ff88;
                    color: black;
                    box-shadow: 0 0 15px #00ff88;
                }

            /* INPUTS */
            .form-control {
                background: #0f0f0f;
                border: 1px solid #00ff88;
                color: white;
            }

                .form-control:focus {
                    box-shadow: 0 0 10px #00ff88;
                    border-color: #00ff88;
                    background: #0f0f0f;
                    color: white;
                }

            /* SALDO */
            .saldo {
                font-size: 2.5rem;
                color: #00ff88;
                text-shadow: 0 0 10px #00ff88;
            }
    </style>
</head>
<body>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>